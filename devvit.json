{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "crowd-vs-cloud",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create today's game",
        "description": "Start a new Crowd vs Cloud round",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "→ Start Voting Phase",
        "description": "Inject AI answers and open voting",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/advance-to-vote"
      },
      {
        "label": "→ Reveal Results",
        "description": "Calculate scores and show the reveal",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/advance-to-results"
      }
    ]
  },
  "forms": {
    "create-game": "/internal/form/create-game"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "crowd_vs_cloud_dev"
  }
}
